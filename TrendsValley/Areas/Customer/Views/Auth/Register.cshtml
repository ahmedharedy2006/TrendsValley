@model RegisterViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> signinManager
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/fonts/material-icon/css/material-design-iconic-font.min.css">
<div class="main">
    <section class="signup">
        <div class="container">
            <div class="signup-content">
                <div class="signup-form">
                    <h2 class="form-title">Register</h2>
                    <form method="POST" class="register-form" id="register-form">
                        @* First Name *@
                        <div class="form-group">
                            <label for="name"><i class="zmdi zmdi-account material-icons-name"></i></label>
                            <input asp-for="appUser.Fname" type="text" name="name" id="name" placeholder="First Name" />
                            <span asp-validation-for="appUser.Fname" class="text-danger"></span>
                        </div>

                        @* Last Name *@
                        <div class="form-group">
                            <label for="name"><i class="zmdi zmdi-account material-icons-name"></i></label>
                            <input asp-for="appUser.Lname" type="text" name="name" id="name" placeholder="Last Name" />
                            <span asp-validation-for="appUser.Lname" class="text-danger"></span>
                        </div>


                        @* Email *@
                        <div class="form-group">
                            <label asp-for="appUser.Email" for="email"><i class="zmdi zmdi-email"></i></label>
                            <input asp-for="appUser.Email" type="email" name="email" id="email" placeholder="Your Email" />
                            <span asp-validation-for="appUser.Email" class="text-danger"></span>
                        </div>
                        @* Password *@
                        <div class="form-group">
                            <label asp-for="Password" for="pass"><i class="zmdi zmdi-lock"></i></label>
                            <input asp-for="Password" type="password" name="pass" id="pass" placeholder="Password" />
                            <span asp-validation-for="Password" class="text-danger"></span>

                        </div>
                        @* Confirm Password *@
                        <div class="form-group">
                            <label asp-for="ConfirmPassword" for="re-pass"><i class="zmdi zmdi-lock-outline"></i></label>
                            <input asp-for="ConfirmPassword" type="password" name="re_pass" id="re_pass" placeholder="Repeat your password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        @* Select City *@
                        <div class="form-group">
                            <label class="col-12"></label>
                            <select asp-for="appUser.CityId" class="form-select" asp-items="@Model.CityList">
                                <option disabled selected>--Select City--</option>
                            </select>
                            <span asp-validation-for="appUser.CityId" class="text-danger"></span>

                        </div>
                        @* Select State *@
                        <div class="form-group">
                            <label for="re-pass"><i></i></label>
                            <select asp-for="appUser.StateId" class="form-select" asp-items="@Model.Statelist">
                                <option disabled selected>--Select State--</option>
                            </select>
                            <span asp-validation-for="appUser.StateId" class="text-danger"></span>

                        </div>

                        @* Postal Code *@
                        <div class="form-group">
                            <label asp-for="appUser.PostalCode" for="pass"><i class="zmdi zmdi-lock"></i></label>
                            <input asp-for="appUser.PostalCode" type="text" name="name" id="name"  placeholder="Postal Code" />
                            <span asp-validation-for="appUser.PostalCode" class="text-danger"></span>

                        </div>
                        <div class="form-group">
                            <input type="checkbox" name="agree-term" id="agree-term" class="agree-term" />
                            <label for="agree-term" class="label-agree-term"><span><span></span></span>I agree all statements in  <a href="#" class="term-service">Terms of service</a></label>
                        </div>
                        <div class="form-group form-button">
                            <input type="submit" name="signup" id="signup" class="form-submit" value="Register" />
                        </div>
                    </form>
                </div>
                <div class="signup-image">
                    <figure><img src="/pics/signup-image.jpg" alt="sing up image"></figure>
                    <a href="#" class="signup-image-link">I am already member</a>
                </div>
            </div>
        </div>
    </section>
</div>
<script src="vendor/jquery/jquery.min.js"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
